echo ==========================================
echo 5?? ?????? Swagger
echo ==========================================
echo.

echo ?????? Swagger...
curl -I http://10.0.0.17:8099/swagger/ 2>nul | findstr "200"

if %ERRORLEVEL% EQU 0 (
