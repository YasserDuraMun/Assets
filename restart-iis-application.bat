@echo off
echo ===============================================
echo     ????? ????? IIS Application
echo ===============================================
echo.

echo ?????: ????? ??????? ???? ?????? ?? IIS
echo.

echo ==========================================
echo 1?? ????? ????? Application Pool
echo ==========================================
echo.

:: Try to recycle application pool using iisreset
echo ?????? ????? ????? IIS...
iisreset /timeout:60

if %ERRORLEVEL% EQU 0 (
    echo ? ?? ????? ????? IIS ?????
) else (
    echo ??  ??? ?? iisreset? ?????? ?????...
    
    :: Try using appcmd if available
    if exist "%SystemRoot%\System32\inetsrv\appcmd.exe" (
        echo ?????? ????? ????? Application Pool...
        "%SystemRoot%\System32\inetsrv\appcmd.exe" recycle apppool /apppool.name:"DefaultAppPool"
        
        echo ?????? restart ??? sites...
        "%SystemRoot%\System32\inetsrv\appcmd.exe" start site "Default Web Site"
    ) else (
        echo ? appcmd ??? ????
    )
)

echo.
echo ==========================================
echo 2?? ??? ???????? ??????
echo ==========================================
echo.

echo ??? ?????? .NET...
tasklist /FI "IMAGENAME eq dotnet.exe" /FO TABLE

echo.
echo ??? ?????? IIS Express...
tasklist /FI "IMAGENAME eq iisexpress.exe" /FO TABLE

echo.
echo ??? ?????? w3wp (IIS Worker Process)...
tasklist /FI "IMAGENAME eq w3wp.exe" /FO TABLE

echo.
echo ==========================================
echo 3?? ??? ????????
echo ==========================================
echo.

echo ??? ?????? 8099 (Backend)...
netstat -ano | findstr ":8099"

echo.
echo ??? ?????? 8098 (Frontend)...
netstat -ano | findstr ":8098"

echo.
echo ==========================================
echo 4?? ?????? ???? ??? API
echo ==========================================
echo.

echo ?????? 5 ???? ?? IIS restart...
timeout /t 5 /nobreak >nul

echo ?????? Dashboard API...
curl -s -w "HTTP Status: %%{http_code}\n" http://10.0.0.17:8099/api/dashboard/summary | findstr "200"

if %ERRORLEVEL% EQU 0 (
    echo ? API ???? ???? ?????
) else (
    echo ? API ?? ??????
